{
  "dataRoles": [
    {
      "displayName": "Values",
      "description": "The measurement values to plot on the control chart",
      "name": "values",
      "kind": "Measure"
    },
    {
      "displayName": "Sample (optional)",
      "description": "Sample name or identifier for the x-axis (optional, auto-generated if not provided)",
      "name": "sample",
      "kind": "Grouping"
    },
    {
      "displayName": "Phase (optional)",
      "description": "Phase or period grouping for separate control limits per phase",
      "name": "phase",
      "kind": "Grouping"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "values": { "max": 1 },
          "sample": { "max": 1 },
          "phase": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "select": [
            { "for": { "in": "sample" } },
            { "for": { "in": "phase" } }
          ],
          "dataReductionAlgorithm": { "top": {} }
        },
        "values": {
          "select": [
            { "bind": { "to": "values" } }
          ],
          "dataReductionAlgorithm": { "top": {} }
        }
      }
    }
  ],
  "objects": {
    "controlLines": {
      "displayName": "Control Lines",
      "properties": {
        "show": {
          "displayName": "Show Control Lines",
          "type": { "bool": true }
        },
        "show1Sigma": {
          "displayName": "Show 1-Sigma Lines",
          "type": { "bool": true }
        },
        "show2Sigma": {
          "displayName": "Show 2-Sigma Lines",
          "type": { "bool": true }
        },
        "show3Sigma": {
          "displayName": "Show 3-Sigma Lines (UCL/LCL)",
          "type": { "bool": true }
        },
        "clColor": {
          "displayName": "Center Line Color",
          "description": "Color for the center line (mean)",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "clStyle": {
          "displayName": "Center Line Style",
          "type": { "enumeration": [
            { "displayName": "Solid", "value": "solid" },
            { "displayName": "Dashed", "value": "dashed" },
            { "displayName": "Dotted", "value": "dotted" }
          ]}
        },
        "clWidth": {
          "displayName": "Center Line Width",
          "type": { "numeric": true }
        },
        "uclColor": {
          "displayName": "UCL Color",
          "description": "Color for the Upper Control Limit (+3σ)",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "uclStyle": {
          "displayName": "UCL Style",
          "type": { "enumeration": [
            { "displayName": "Solid", "value": "solid" },
            { "displayName": "Dashed", "value": "dashed" },
            { "displayName": "Dotted", "value": "dotted" }
          ]}
        },
        "uclWidth": {
          "displayName": "UCL Width",
          "type": { "numeric": true }
        },
        "lclColor": {
          "displayName": "LCL Color",
          "description": "Color for the Lower Control Limit (-3σ)",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "lclStyle": {
          "displayName": "LCL Style",
